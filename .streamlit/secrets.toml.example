# ─────────────────────────────────────────────────────────────
# Streamlit Cloud の Secrets に貼り付けるテンプレートです。
# このファイルは Git にコミットして構いません（サンプル値のみ）。
# 実際の値を入れた secrets.toml は .gitignore で除外してください。
# ─────────────────────────────────────────────────────────────

[auth]
# Google OAuth のコールバック先（デプロイ先に合わせて変更）
redirect_uri = "https://your-app-name.streamlit.app/oauth2callback"
# ランダムな文字列（32文字以上推奨）。openssl rand -base64 32 などで生成
cookie_secret = "REPLACE_WITH_RANDOM_32CHAR_STRING"

[auth.google]
client_id     = "YOUR_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"

[anthropic]
api_key = "sk-ant-..."

[supabase]
url = "https://xxxxxxxxxxxx.supabase.co"
key = "eyJhbGci..."   # anon public key（Project Settings > API）
